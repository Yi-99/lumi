{
  "manifest_version": 3,
  "name": "Lumi",
  "version": "0.1.0",
  "description": "Highlight any text, get instant answers from multiple LLMs in a macOS Lookup-style card.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "action": {
    "default_title": "Lumi — open settings",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/lumi-16.png",
      "32": "icons/lumi-32.png",
      "48": "icons/lumi-48.png",
      "128": "icons/lumi-128.png"
    }
  },
  "commands": {
    "trigger-lookup": {
      "suggested_key": { "default": "Ctrl+Shift+L", "mac": "Command+Shift+L" },
      "description": "Look up current selection"
    }
  },
  "icons": {
    "16": "icons/lumi-16.png",
    "32": "icons/lumi-32.png",
    "48": "icons/lumi-48.png",
    "128": "icons/lumi-128.png"
  }
}
